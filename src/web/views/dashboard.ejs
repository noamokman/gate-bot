<%- include('partials/header') %>
  <% if (typeof message !== 'undefined' && message) { %>
    <div class="message message-info"><%= message.replace(/\n/g, '<br>') %></div>
  <% } %>

  <div class="card">
    <h1><%= t('dashboard.title') %></h1>
    <p><%= t('dashboard.signedInAs') %> <strong><%= user.name %></strong> (<%= user.email %>)</p>
    <% if (isAllowed) { %>
      <div class="message message-success"><%= t('dashboard.authorized') %></div>
      <form method="post" action="/dashboard/open">
        <button type="submit" class="btn"><%= t('dashboard.openGate') %></button>
      </form>
    <% } else { %>
      <div class="message message-error"><%= t('dashboard.notAuthorized') %></div>
      <form method="post" action="/dashboard/request-access">
        <button type="submit" class="btn"><%= t('dashboard.requestAccess') %></button>
      </form>
    <% } %>
  </div>

  <% if (isAllowed && (doorCode || parkingInfo || floor || unit || propertyNotes)) { %>
    <div class="card">
      <h1><%= t('dashboard.propertyInfo') %></h1>
      <table>
        <% if (doorCode) { %><tr><td><strong><%= t('dashboard.doorCode') %></strong></td><td><%= doorCode %></td></tr><% } %>
        <% if (parkingInfo) { %><tr><td><strong><%= t('dashboard.infoParking') %></strong></td><td><%= parkingInfo %></td></tr><% } %>
        <% if (floor) { %><tr><td><strong><%= t('dashboard.infoFloor') %></strong></td><td><%= floor %></td></tr><% } %>
        <% if (unit) { %><tr><td><strong><%= t('dashboard.infoUnit') %></strong></td><td><%= unit %></td></tr><% } %>
        <% if (propertyNotes) { %><tr><td><strong><%= t('dashboard.infoNotes') %></strong></td><td><%= propertyNotes %></td></tr><% } %>
      </table>
    </div>
  <% } %>

  <% if (!isAllowed) { %>
  <script>
    (function() {
      var pollId;

      function checkAuth() {
        fetch('/dashboard/status')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.allowed) {
              clearInterval(pollId);
              location.reload();
            }
          });
      }

      pollId = setInterval(checkAuth, 3000);
    })();
  </script>
  <% } %>
<%- include('partials/footer') %>
