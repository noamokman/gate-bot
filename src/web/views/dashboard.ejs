<%- include('partials/header') %>
  <% if (typeof message !== 'undefined' && message) { %>
    <div class="message message-info"><%= message.replace(/\n/g, '<br>') %></div>
  <% } %>

  <div class="card">
    <h1><%= t('dashboard.title') %></h1>
    <p><%= t('dashboard.signedInAs') %> <strong><%= user.name %></strong> (<%= user.email %>)</p>
    <% if (isAllowed) { %>
      <div class="message message-success"><%= t('dashboard.authorized') %></div>
      <form method="post" action="/dashboard/open">
        <button type="submit" class="btn"><%= t('dashboard.openGate') %></button>
      </form>
      <% if (doorCode) { %>
        <div class="card mt-1">
          <h1><%= t('dashboard.doorCode') %></h1>
          <p style="font-size: 1.5rem; font-weight: 700; letter-spacing: 0.25em; text-align: center;"><%= doorCode %></p>
        </div>
      <% } %>
    <% } else { %>
      <div class="message message-error"><%= t('dashboard.notAuthorized') %></div>
      <form method="post" action="/dashboard/request-access">
        <button type="submit" class="btn"><%= t('dashboard.requestAccess') %></button>
      </form>
    <% } %>
  </div>

  <% if (!isAllowed) { %>
  <script>
    (function() {
      var pollId;

      function checkAuth() {
        fetch('/dashboard/status')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.allowed) {
              clearInterval(pollId);
              location.reload();
            }
          });
      }

      pollId = setInterval(checkAuth, 3000);
    })();
  </script>
  <% } %>
<%- include('partials/footer') %>
