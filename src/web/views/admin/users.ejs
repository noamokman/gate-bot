<%- include('../partials/header') %>
  <div class="card">
    <h1><%= t('admin.allowedUsers') %></h1>
    <% if (allowedUsers.length === 0) { %>
      <p><%= t('admin.noUsers') %></p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th><%= t('admin.name') %></th>
            <th><%= t('admin.source') %></th>
            <th><%= t('admin.contact') %></th>
            <th><%= t('admin.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% allowedUsers.forEach(function(u) { %>
            <tr>
              <td><%= u.name %></td>
              <td><span class="badge badge-<%= u.sourceType %>"><%= u.sourceType %></span></td>
              <td><%= u.email || u.sourceUserId %></td>
              <td>
                <form method="post" action="/admin/users/<%= u.sourceType %>/<%= u.sourceUserId %>/remove" class="inline">
                  <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;"><%= t('admin.remove') %></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
  <a href="/admin">&larr; <%= t('admin.back') %></a>
<%- include('../partials/footer') %>
