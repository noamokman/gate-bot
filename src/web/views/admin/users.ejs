<%- include('../partials/header') %>
  <div class="card">
    <h1>Allowed Users</h1>
    <% if (allowedUsers.length === 0) { %>
      <p>No allowed users.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Source</th>
            <th>Contact</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% allowedUsers.forEach(function(u) { %>
            <tr>
              <td><%= u.name %></td>
              <td><span class="badge badge-<%= u.sourceType %>"><%= u.sourceType %></span></td>
              <td><%= u.email || u.sourceUserId %></td>
              <td>
                <form method="post" action="/admin/users/<%= u.sourceType %>/<%= u.sourceUserId %>/remove" class="inline">
                  <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
  <a href="/admin">&larr; Back to Admin</a>
<%- include('../partials/footer') %>
