<%- include('../partials/header') %>
  <div class="card">
    <h1><%= t('admin.pendingRequests') %></h1>
    <% if (pendingRequests.length === 0) { %>
      <p><%= t('admin.noPending') %></p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th><%= t('admin.name') %></th>
            <th><%= t('admin.source') %></th>
            <th><%= t('admin.contact') %></th>
            <th><%= t('admin.requested') %></th>
            <th><%= t('admin.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% pendingRequests.forEach(function(r) { %>
            <tr>
              <td><%= r.name || 'Unknown' %></td>
              <td><span class="badge badge-<%= r.sourceType %>"><%= r.sourceType %></span></td>
              <td><%= r.email || r.sourceUserId %></td>
              <td><%= new Date(r.requestedAt).toLocaleString() %></td>
              <td>
                <form method="post" action="/admin/pending/<%= r.id %>/allow" class="inline">
                  <button type="submit" class="btn btn-success" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;"><%= t('admin.allow') %></button>
                </form>
                <form method="post" action="/admin/pending/<%= r.id %>/deny" class="inline">
                  <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;"><%= t('admin.deny') %></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
  <a href="/admin">&larr; <%= t('admin.back') %></a>
<%- include('../partials/footer') %>
